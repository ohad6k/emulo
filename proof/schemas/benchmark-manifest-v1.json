{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ohad6k/ditto/proof/schemas/benchmark-manifest-v1.json",
  "title": "Ditto Proof v1 benchmark manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "benchmark", "benchmark_version", "ditto_ref", "ditto_commit",
    "profile_manifest_sha256", "private_rubric_sha256", "public_rubric_sha256",
    "uncertainty_policy", "host_persistent_context", "systems", "pairs",
    "limitations", "created_at"
  ],
  "properties": {
    "schema": {"const": "ditto-proof/1"},
    "benchmark": {"const": "Ditto Proof v1"},
    "benchmark_version": {"const": "1.0.0"},
    "ditto_ref": {"const": "v0.3.7"},
    "ditto_commit": {"const": "5f4008b0c0df40dcadb92c8fd1ba4dcf3aee40d0"},
    "profile_manifest_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "private_rubric_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "public_rubric_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "uncertainty_policy": {"const": "small-n, directional only; Wilson 95%; no significance claims"},
    "host_persistent_context": {"const": "absent"},
    "systems": {
      "type": "array", "minItems": 2, "maxItems": 2,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": [
          "system_id", "host", "menu_label", "model_id", "host_version",
          "run_argv", "ditto_install_argv", "selection_screenshot_sha256",
          "tool_policy_sha256", "permission_policy_sha256", "quota_snapshot",
          "expected_cost"
        ],
        "properties": {
          "system_id": {"type": "string", "minLength": 1},
          "host": {"enum": ["codex", "claude"]},
          "menu_label": {"type": "string", "minLength": 1},
          "model_id": {"type": ["string", "null"]},
          "host_version": {"type": "string", "minLength": 1},
          "run_argv": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "ditto_install_argv": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "selection_screenshot_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "tool_policy_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "permission_policy_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "quota_snapshot": {"type": "string", "minLength": 1},
          "expected_cost": {"type": "string", "minLength": 1}
        }
      }
    },
    "pairs": {
      "type": "array", "minItems": 24, "maxItems": 24,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": [
          "pair_id", "system_id", "host", "task_id", "family", "variant",
          "trial", "fixture_sha256", "instruction_sha256", "tool_policy_sha256",
          "permission_policy_sha256", "budget", "cells"
        ],
        "properties": {
          "pair_id": {"type": "string", "minLength": 1},
          "system_id": {"type": "string", "minLength": 1},
          "host": {"enum": ["codex", "claude"]},
          "task_id": {"type": "string", "minLength": 1},
          "family": {"enum": ["work", "design", "write"]},
          "variant": {"enum": ["primary", "held-out"]},
          "trial": {"enum": [1, 2]},
          "fixture_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "instruction_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "tool_policy_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "permission_policy_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "budget": {
            "type": "object", "additionalProperties": false,
            "required": ["time_seconds", "max_turns"],
            "properties": {
              "time_seconds": {"type": "integer", "minimum": 1},
              "max_turns": {"type": "integer", "minimum": 1}
            }
          },
          "cells": {
            "type": "array", "minItems": 2, "maxItems": 2,
            "items": {
              "type": "object", "additionalProperties": false,
              "required": [
                "pair_id", "system_id", "host", "task_id", "family", "variant",
                "trial", "fixture_sha256", "instruction_sha256", "tool_policy_sha256",
                "permission_policy_sha256", "budget", "condition", "order", "cell_id",
                "review_id", "profile_manifest_sha256", "host_persistent_context"
              ],
              "properties": {
                "pair_id": {"type": "string", "minLength": 1},
                "system_id": {"type": "string", "minLength": 1},
                "host": {"enum": ["codex", "claude"]},
                "task_id": {"type": "string", "minLength": 1},
                "family": {"enum": ["work", "design", "write"]},
                "variant": {"enum": ["primary", "held-out"]},
                "trial": {"enum": [1, 2]},
                "fixture_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
                "instruction_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
                "tool_policy_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
                "permission_policy_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
                "budget": {"type": "object"},
                "condition": {"enum": ["cold", "ditto"]},
                "order": {"enum": [1, 2]},
                "cell_id": {"type": "string", "minLength": 1},
                "review_id": {"type": "string", "minLength": 1},
                "profile_manifest_sha256": {"type": ["string", "null"]},
                "host_persistent_context": {"const": "absent"}
              }
            }
          }
        }
      }
    },
    "limitations": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "created_at": {"type": "string", "format": "date-time"}
  }
}
