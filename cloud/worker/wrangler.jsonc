{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "emulo-autopilot-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-16",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "observability": {
    "enabled": false
  },
  "vars": {
    "APP_ENV": "local",
    "GITHUB_CLIENT_ID": "not-configured",
    "PUBLIC_BASE_URL": "https://not-configured.invalid/",
    "PAID_CHECKOUT_ENABLED": "false",
    "POLAR_SERVER": "sandbox",
    "POLAR_MONTHLY_PRODUCT_ID": "not-configured",
    "POLAR_YEARLY_PRODUCT_ID": "not-configured"
  },
  "secrets": {
    "required": ["POLAR_WEBHOOK_SECRET", "GITHUB_CLIENT_SECRET", "POLAR_ACCESS_TOKEN"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "emulo-autopilot-beta",
      "migrations_dir": "migrations"
    }
  ]
}
